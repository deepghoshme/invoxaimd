# invoxai.io — Caddy reverse proxy + automatic HTTPS
# Reverse-proxies every domain to the Next.js app on 127.0.0.1:3000.
#
# - Apex / www / app / admin           → normal ACME (HTTP-01), issued up front.
# - Seller subdomains (*.invoxai.io)   → on-demand TLS, gated by /api/tls-check.
# - Seller custom domains              → on-demand TLS, gated by /api/tls-check.
#
# Install: see deploy/README.md. Lives at /etc/caddy/Caddyfile.

{
	# ACME account email (renewal + expiry notices).
	email iamdeep.mk@gmail.com

	# Ask the app before minting a cert for any unknown hostname, so we never
	# issue certs for DNS we don't actually serve (Let's Encrypt rate limits).
	on_demand_tls {
		ask http://127.0.0.1:3000/api/tls-check
	}
}

# --- Platform surfaces (known hostnames, certs issued immediately) ---
invoxai.io, www.invoxai.io, app.invoxai.io, admin.invoxai.io {
	# Send www → apex (canonical).
	@www host www.invoxai.io
	redir @www https://invoxai.io{uri} permanent

	encode zstd gzip
	reverse_proxy 127.0.0.1:3000
}

# --- Everything else: seller subdomains + custom domains (on-demand TLS) ---
https:// {
	tls {
		on_demand
	}
	encode zstd gzip
	reverse_proxy 127.0.0.1:3000
}
